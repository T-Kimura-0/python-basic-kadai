   "source": [
    "class Human:\n",
    "    def __init__(self, name, age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "\n",
    "    def printinfo(self):\n",
    "        human_name = self.name\n",
    "        human_age = self.age\n",
    "\n",
    "        print(f\"人名→{human_name}、年齢→{human_age}\")\n",
    "\n",
    "human_1 = Human(\"samurai\", 34)\n",
    "human_1.printinfo()\n"
   ]
  }
 ],
